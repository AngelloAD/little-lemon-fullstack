{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/main.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/assets/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend",
        "path": "assets/$1"
      }
    },
    {
      "source": "/((?!api|assets).*)*",
      "destination": {
        "type": "service",
        "service": "frontend",
        "path": "index.html"
      }
    }
  ]
}
